{
  "manifest_version": 3,
  "name": "SafeGuard Shield",
  "description": "Browser extension that warns about phishing, suspicious links, and risky browsing patterns.",
  "version": "0.2.0",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "SafeGuard Shield",
    "default_popup": "popup.html"
  }
}
