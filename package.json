{
  "name": "safeguard-shield-extension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:css": "tailwindcss -i ./src/popup/styles.css -o ./src/popup/tailwind.generated.css --minify",
    "build": "npm run build:css && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.2",
    "vite": "^7.0.0"
  }
}
